APP_PORT=8080
POSTGRES_USER=user
POSTGRES_PASSWORD=user
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
REACT_APP_BASE_API_URL=http://localhost:8080

# LLM (OpenAI-совместимый сервер: llama.cpp, vLLM и т.д.)
# Локальный запуск (API не в Docker):
VLLM_BASE_URL=http://localhost:8001/v1
# API в Docker, LLM на хосте (Mac/Windows):
# VLLM_BASE_URL=http://host.docker.internal:8001/v1
LLM_DEFAULT_MODEL=models/Qwen3-8B-Q4_K_M.gguf

# Модель на агента (опционально; если не задано — используется LLM_DEFAULT_MODEL)
# LLM_MODEL_HR=model-hr
# LLM_MODEL_TECH_LEAD=model-tech
# LLM_MODEL_MENTOR=model-mentor
# LLM_MODEL_CODE_REVIEW=model-codereview

# RAG (Tech Interview Handbook)
RAG_ENABLED=true
# Путь до handbook внутри контейнера:
RAG_HANDBOOK_DIR=/app/tech-interview-handbook-main/apps/website
# Persist директория индекса Chroma:
RAG_PERSIST_DIR=/app/rag_store
RAG_COLLECTION=tech_interview_handbook
RAG_EMBED_MODEL=BAAI/bge-small-en-v1.5
RAG_TOP_K=6
RAG_MAX_CONTEXT_CHARS=6000